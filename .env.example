# ============================================================================
# Crab Harness Platform (PostgreSQL, Redis, JWT)
# ============================================================================
# These are required for the multi-tenant platform layer.
# Default values match backend/docker-compose.dev.yml — no changes needed for local dev.

# PostgreSQL connection (asyncpg)
# CRAB_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crab

# Redis connection
# CRAB_REDIS_URL=redis://localhost:6379/0

# JWT signing secret — MUST change in production!
CRAB_JWT_SECRET=local-dev-only-jwt-secret-change-me-123456

# Gateway instance ID (used for run crash recovery across restarts)
# CRAB_INSTANCE_ID=gateway-1

# Object storage backend
# Local dev default is the local filesystem backend.
# Set CRAB_STORAGE_BACKEND=bos to switch uploads/custom skills to Baidu BOS.
# CRAB_STORAGE_BACKEND=local

# Baidu BOS (required when CRAB_STORAGE_BACKEND=bos)
# CRAB_BOS_ACCESS_KEY=your-bos-access-key
# CRAB_BOS_SECRET_KEY=your-bos-secret-key
# CRAB_BOS_ENDPOINT=https://bj.bcebos.com
# CRAB_BOS_BUCKET=crab-harness

# E2B cloud sandbox (used when config.yaml sets sandbox.use=crab_platform.sandbox:E2BSandboxProvider)
# E2B_API_KEY=your-e2b-api-key
# Optional: E2B_API_URL=https://api.e2b.dev

# ============================================================================
# LLM Provider API Keys
# ============================================================================
# TAVILY API Key
TAVILY_API_KEY=your-tavily-api-key

# Jina API Key
JINA_API_KEY=your-jina-api-key

# InfoQuest API Key
INFOQUEST_API_KEY=your-infoquest-api-key
# CORS Origins (comma-separated) - e.g., http://localhost:3000,http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Optional:
# FIRECRAWL_API_KEY=your-firecrawl-api-key
# VOLCENGINE_API_KEY=your-volcengine-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai
# MINIMAX_API_KEY=your-minimax-api-key  # OpenAI-compatible, see https://platform.minimax.io

# ============================================================================
# Observability (optional)
# ============================================================================
# Enable LangSmith to monitor and debug your LLM calls, agent runs, and tool executions.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key
# LANGSMITH_PROJECT=your-langsmith-project

# ============================================================================
# External Integrations (optional)
# ============================================================================
# GitHub API Token
# GITHUB_TOKEN=your-github-token
